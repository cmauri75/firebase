rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /cartItems/{itemId} {
      // Allow anonymous writes only for well-formed new cart entries.
      allow create: if request.resource.data.keys().hasOnly(['text', 'createdAt'])
                    && request.resource.data.text is string
                    && request.resource.data.text.size() > 0
                    && request.resource.data.text.size() <= 120
                    && request.resource.data.createdAt == request.time;

      // Client app does not need to read, edit, or delete entries.
      allow read, update, delete: if false;
    }

    // Deny all other paths by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
